{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "noImplicitAny": false,
    "paths": {
      "@blink/shared/*": [
        "packages/shared/src/*"
      ],
      "@blink/database/*": [
        "packages/database/*"
      ],
      "@blink/ai/*": [
        "packages/ai/src/*"
      ],
      "@blink/parsers/*": [
        "packages/parsers/src/*"
      ]
    }
  }
}
